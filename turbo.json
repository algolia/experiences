{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"],
      "env": ["DEPLOY_PRIME_URL"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {},
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["DASHBOARD_BASE"]
    }
  }
}
